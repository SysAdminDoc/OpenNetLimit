<Window x:Class="OpenNetLimit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenNetLimit" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="OpenNetLimit" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <Ellipse Width="10" Height="10" Margin="12,0,4,0"
                     Fill="{Binding StatusColor}" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="Gray"/>
        </StackPanel>

        <!-- Summary -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Margin="0,0,24,0">
                <Run Text="Download: " Foreground="Gray"/>
                <Run Text="{Binding TotalDownload, Mode=OneWay}" FontWeight="SemiBold" Foreground="#2196F3"/>
            </TextBlock>
            <TextBlock>
                <Run Text="Upload: " Foreground="Gray"/>
                <Run Text="{Binding TotalUpload, Mode=OneWay}" FontWeight="SemiBold" Foreground="#4CAF50"/>
            </TextBlock>
        </StackPanel>

        <!-- Process list -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Processes}" Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="180"/>
                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="60"/>
                <DataGridTextColumn Header="Download/s" Binding="{Binding DownloadDisplay}" Width="120"/>
                <DataGridTextColumn Header="Upload/s" Binding="{Binding UploadDisplay}" Width="120"/>
                <DataGridTextColumn Header="Total Down" Binding="{Binding TotalDownDisplay}" Width="120"/>
                <DataGridTextColumn Header="Total Up" Binding="{Binding TotalUpDisplay}" Width="120"/>
                <DataGridTextColumn Header="Limit" Binding="{Binding LimitDisplay}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <StatusBar Grid.Row="3" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding ActiveConnectionCount, StringFormat='Connections: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ActiveRuleCount, StringFormat='Active Rules: {0}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
