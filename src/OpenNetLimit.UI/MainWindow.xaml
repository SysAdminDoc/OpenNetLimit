<Window x:Class="OpenNetLimit.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenNetLimit" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        KeyboardNavigation.TabNavigation="Cycle">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12"
                    AutomationProperties.Name="Service status">
            <TextBlock Text="OpenNetLimit" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <Ellipse Width="10" Height="10" Margin="12,0,4,0"
                     Fill="{Binding StatusColor}" VerticalAlignment="Center"
                     AutomationProperties.Name="{Binding StatusText}"/>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="Gray"
                       AutomationProperties.LiveSetting="Polite"/>
        </StackPanel>

        <!-- Summary -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8"
                    AutomationProperties.Name="Traffic summary">
            <TextBlock Margin="0,0,24,0"
                       AutomationProperties.Name="{Binding TotalDownload, StringFormat='Download speed: {0}'}">
                <Run Text="Download: " Foreground="Gray"/>
                <Run Text="{Binding TotalDownload, Mode=OneWay}" FontWeight="SemiBold" Foreground="#2196F3"/>
            </TextBlock>
            <TextBlock AutomationProperties.Name="{Binding TotalUpload, StringFormat='Upload speed: {0}'}">
                <Run Text="Upload: " Foreground="Gray"/>
                <Run Text="{Binding TotalUpload, Mode=OneWay}" FontWeight="SemiBold" Foreground="#4CAF50"/>
            </TextBlock>
        </StackPanel>

        <!-- Process list -->
        <DataGrid Grid.Row="2" x:Name="ProcessGrid" ItemsSource="{Binding Processes}" Style="{StaticResource DataGridStyle}"
                  AutomationProperties.Name="Process traffic list">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Set Bandwidth Limit..." Click="OnSetLimit" IsEnabled="{Binding IsAdmin}"/>
                    <MenuItem Header="Remove Limit" Click="OnRemoveLimit" IsEnabled="{Binding IsAdmin}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="180"/>
                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="60"/>
                <DataGridTextColumn Header="Download/s" Binding="{Binding DownloadDisplay}" Width="120"/>
                <DataGridTextColumn Header="Upload/s" Binding="{Binding UploadDisplay}" Width="120"/>
                <DataGridTextColumn Header="Total Down" Binding="{Binding TotalDownDisplay}" Width="120"/>
                <DataGridTextColumn Header="Total Up" Binding="{Binding TotalUpDisplay}" Width="120"/>
                <DataGridTextColumn Header="Limit" Binding="{Binding LimitDisplay}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <StatusBar Grid.Row="3" Margin="0,8,0,0"
                   AutomationProperties.Name="Status bar">
            <StatusBarItem AutomationProperties.Name="{Binding ActiveConnectionCount, StringFormat='Connections: {0}'}">
                <TextBlock Text="{Binding ActiveConnectionCount, StringFormat='Connections: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem AutomationProperties.Name="{Binding ActiveRuleCount, StringFormat='Active Rules: {0}'}">
                <TextBlock Text="{Binding ActiveRuleCount, StringFormat='Active Rules: {0}'}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem AutomationProperties.Name="{Binding PermissionDisplay, StringFormat='Mode: {0}'}">
                <TextBlock Text="{Binding PermissionDisplay, StringFormat='Mode: {0}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
