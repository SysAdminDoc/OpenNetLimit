<Window x:Class="OpenNetLimit.UI.SetLimitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Bandwidth Limit" Height="220" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <Grid Margin="16" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,12"
                   Text="{Binding ProcessName, StringFormat='Limit bandwidth for: {0}'}"
                   FontWeight="SemiBold"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Download:" VerticalAlignment="Center" Margin="0,0,8,4"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="DownloadBox" Text="0" Margin="0,0,4,4"
                 AutomationProperties.Name="Download limit in KB/s"/>
        <TextBlock Grid.Row="1" Grid.Column="2" Text="KB/s" VerticalAlignment="Center" Margin="0,0,0,4"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Upload:" VerticalAlignment="Center" Margin="0,0,8,4"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="UploadBox" Text="0" Margin="0,0,4,4"
                 AutomationProperties.Name="Upload limit in KB/s"/>
        <TextBlock Grid.Row="2" Grid.Column="2" Text="KB/s" VerticalAlignment="Center" Margin="0,0,0,4"/>

        <TextBlock Grid.Row="3" Grid.ColumnSpan="3" Text="Set to 0 to remove limit." Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,0" FontSize="11"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
