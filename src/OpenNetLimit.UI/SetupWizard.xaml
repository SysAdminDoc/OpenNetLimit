<Window x:Class="OpenNetLimit.UI.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenNetLimit — First-Run Setup" Height="400" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Wizard pages -->
        <TabControl x:Name="Pages" Grid.Row="0" Margin="16,16,16,0"
                    BorderThickness="0"
                    TabStripPlacement="Left"
                    Background="Transparent">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- Page 1: Welcome -->
            <TabItem>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Welcome to OpenNetLimit" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,0,0,12">
                        OpenNetLimit monitors and controls per-application network bandwidth on your Windows PC.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="Gray">
                        This wizard will help you configure the essential settings. You can change these later at any time.
                    </TextBlock>
                </StackPanel>
            </TabItem>

            <!-- Page 2: Requirements -->
            <TabItem>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Requirements" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8" FontSize="13">
                        &#x2022; Administrator privileges are required to load the WinDivert network driver.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8" FontSize="13">
                        &#x2022; The OpenNetLimit service must be running for monitoring and limiting to work.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8" FontSize="13">
                        &#x2022; Some antivirus or EDR software may flag the WinDivert driver. Add an exception if needed.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,12,0,0" FontSize="12">
                        Traffic rules, statistics, and logs are stored in %ProgramData%\OpenNetLimit.
                    </TextBlock>
                </StackPanel>
            </TabItem>

            <!-- Page 3: Ready -->
            <TabItem>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="You're all set!" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,0,0,8">
                        OpenNetLimit will connect to the background service and start showing your network activity.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,0,0,8">
                        Right-click any process in the list to set bandwidth limits. Use the system tray icon for quick access.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,12,0,0" FontSize="12">
                        Click Finish to open the main window.
                    </TextBlock>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Navigation buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16">
            <Button x:Name="BtnBack" Content="Back" Width="80" Margin="0,0,8,0" Click="OnBack" IsEnabled="False"/>
            <Button x:Name="BtnNext" Content="Next" Width="80" Margin="0,0,8,0" Click="OnNext" IsDefault="True"/>
            <Button Content="Skip" Width="80" Click="OnSkip"/>
        </StackPanel>
    </Grid>
</Window>
