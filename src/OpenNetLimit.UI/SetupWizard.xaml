<Window x:Class="OpenNetLimit.UI.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OpenNetLimit.UI.Services"
        Title="{loc:Loc Setup_Title}" Height="400" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Wizard pages -->
        <TabControl x:Name="Pages" Grid.Row="0" Margin="16,16,16,0"
                    BorderThickness="0"
                    TabStripPlacement="Left"
                    Background="Transparent">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- Page 1: Welcome -->
            <TabItem>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{loc:Loc Setup_WelcomeTitle}" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Text="{loc:Loc Setup_WelcomeBody}" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,12"/>
                    <TextBlock Text="{loc:Loc Setup_WelcomeHint}" TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>
            </TabItem>

            <!-- Page 2: Requirements -->
            <TabItem>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{loc:Loc Setup_RequirementsTitle}" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Text="{loc:Loc Setup_RequirementsPrivileges}" TextWrapping="Wrap" Margin="0,0,0,8" FontSize="13"/>
                    <TextBlock Text="{loc:Loc Setup_RequirementsService}" TextWrapping="Wrap" Margin="0,0,0,8" FontSize="13"/>
                    <TextBlock Text="{loc:Loc Setup_RequirementsAntivirus}" TextWrapping="Wrap" Margin="0,0,0,8" FontSize="13"/>
                    <TextBlock Text="{loc:Loc Setup_RequirementsStorage}" TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" Margin="0,12,0,0" FontSize="12"/>
                </StackPanel>
            </TabItem>

            <!-- Page 3: Ready -->
            <TabItem>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{loc:Loc Setup_ReadyTitle}" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Text="{loc:Loc Setup_ReadyBodyPrimary}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Loc Setup_ReadyBodySecondary}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Loc Setup_ReadyHint}" TextWrapping="Wrap" Foreground="{DynamicResource MutedTextBrush}" Margin="0,12,0,0" FontSize="12"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Navigation buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16">
            <Button x:Name="BtnBack" Content="{loc:Loc Action_Back}" Width="80" Margin="0,0,8,0" Click="OnBack" IsEnabled="False"/>
            <Button x:Name="BtnNext" Content="{loc:Loc Action_Next}" Width="80" Margin="0,0,8,0" Click="OnNext" IsDefault="True"/>
            <Button Content="{loc:Loc Action_Skip}" Width="80" Click="OnSkip"/>
        </StackPanel>
    </Grid>
</Window>
